{
  "name": "lintp-cli",
  "version": "0.4.1",
  "description": "File system linter with a custom DSL for directory structure validation",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "lintp": "./bin/lintp"
  },
  "scripts": {
    "build": "wireit",
    "build:ts": "wireit",
    "build:rust": "wireit",
    "check": "wireit",
    "check:ts": "wireit",
    "check:rust": "wireit",
    "test": "wireit",
    "test:ts": "wireit",
    "test:rust": "wireit",
    "coverage": "wireit",
    "coverage:ts": "wireit",
    "coverage:rust": "wireit",
    "coverage:check": "wireit",
    "coverage:check:ts": "wireit",
    "coverage:check:rust": "wireit",
    "sync-toml": "wireit",
    "prepublishOnly": "wireit",
    "format": "wireit",
    "format:ts": "wireit",
    "format:rust": "wireit",
    "format:check": "wireit",
    "format:ts:check": "wireit",
    "format:rust:check": "wireit",
    "lint": "wireit",
    "lint:ts": "wireit",
    "lint:rust": "wireit",
    "lint:fix": "wireit",
    "lint:fix:ts": "wireit",
    "lint:fix:rust": "wireit",
    "docs:build": "wireit",
    "docs:preview": "python3 -m http.server 8931 -d _site",
    "prepare": "husky",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narehart/lintp.git"
  },
  "keywords": [
    "linter",
    "file-system",
    "naming-conventions",
    "dsl",
    "validation",
    "cli",
    "rust",
    "fs",
    "path",
    "directory-structure"
  ],
  "author": "Nico Arehart",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/narehart/lintp/issues"
  },
  "homepage": "https://narehart.github.io/lintp/",
  "files": [
    "bin/lintp",
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "//": "optionalDependencies (platform binary packages) are injected at publish time by scripts/sync-optional-deps.ts",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "marked": "^18.0.5",
    "prettier-plugin-rust": "^0.1.9",
    "smol-toml": "^1.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4",
    "wireit": "^0.14.12"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:ts",
        "build:rust"
      ]
    },
    "build:ts": {
      "command": "tsc -p tsconfig.build.json",
      "files": [
        "src/**/*.ts",
        "tsconfig.build.json",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "build:rust": {
      "command": "cargo build --release",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "output": [
        "target/release/**"
      ]
    },
    "check": {
      "dependencies": [
        "check:ts",
        "check:rust"
      ]
    },
    "check:ts": {
      "command": "tsc --noEmit",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsconfig.json"
      ]
    },
    "check:rust": {
      "command": "cargo check",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ]
    },
    "test": {
      "dependencies": [
        "test:ts",
        "test:rust"
      ]
    },
    "test:ts": {
      "command": "vitest run",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "vitest.config.ts"
      ],
      "dependencies": [
        "build:ts"
      ]
    },
    "test:rust": {
      "command": "cargo test",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ]
    },
    "coverage": {
      "dependencies": [
        "coverage:ts",
        "coverage:rust"
      ]
    },
    "coverage:ts": {
      "command": "vitest run --coverage",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/**"
      ],
      "dependencies": [
        "build:ts"
      ]
    },
    "coverage:rust": {
      "command": "cargo tarpaulin --out Html --output-dir target/coverage --fail-under 60",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "output": [
        "target/coverage/**"
      ]
    },
    "coverage:check": {
      "command": "tsx scripts/check-coverage.ts",
      "files": [
        "scripts/check-coverage.ts"
      ],
      "dependencies": [
        "coverage"
      ]
    },
    "coverage:check:ts": {
      "command": "tsx scripts/check-coverage.ts --ts",
      "files": [
        "scripts/check-coverage.ts"
      ],
      "dependencies": [
        "coverage:ts"
      ]
    },
    "coverage:check:rust": {
      "command": "tsx scripts/check-coverage.ts --rust",
      "files": [
        "scripts/check-coverage.ts"
      ],
      "dependencies": [
        "coverage:rust"
      ]
    },
    "docs:build": {
      "command": "tsx scripts/build-docs.ts",
      "files": [
        "scripts/build-docs.ts",
        "docs/**",
        "README.md"
      ],
      "output": [
        "_site/**"
      ]
    },
    "sync-toml": {
      "command": "tsx scripts/sync-toml-to-package.ts",
      "files": [
        "scripts/sync-toml-to-package.ts",
        "Cargo.toml",
        "package.json"
      ]
    },
    "prepublishOnly": {
      "dependencies": [
        "build:ts",
        "sync-toml"
      ]
    },
    "format": {
      "dependencies": [
        "format:ts",
        "format:rust"
      ]
    },
    "format:ts": {
      "command": "prettier --write .",
      "files": [
        "**/*.{ts,js,json,md,yml,yaml}",
        "!dist/**",
        "!target/**",
        "!node_modules/**",
        "!coverage/**"
      ]
    },
    "format:rust": {
      "command": "cargo fmt",
      "files": [
        "src/**/*.rs",
        "Cargo.toml"
      ]
    },
    "format:check": {
      "dependencies": [
        "format:ts:check",
        "format:rust:check"
      ]
    },
    "format:ts:check": {
      "command": "prettier --check .",
      "files": [
        "**/*.{ts,js,json,md,yml,yaml}",
        "!dist/**",
        "!target/**",
        "!node_modules/**",
        "!coverage/**"
      ]
    },
    "format:rust:check": {
      "command": "cargo fmt -- --check",
      "files": [
        "src/**/*.rs",
        "Cargo.toml"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:ts",
        "lint:rust"
      ]
    },
    "lint:ts": {
      "command": "eslint .",
      "files": [
        "**/*.{ts,js}",
        "!dist/**",
        "!target/**",
        "!node_modules/**",
        "!coverage/**",
        "eslint.config.js"
      ],
      "dependencies": [
        "check:ts"
      ]
    },
    "lint:rust": {
      "command": "cargo clippy -- -D warnings",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "dependencies": [
        "check:rust"
      ]
    },
    "lint:fix": {
      "dependencies": [
        "lint:fix:ts",
        "lint:fix:rust"
      ]
    },
    "lint:fix:ts": {
      "command": "eslint . --fix",
      "files": [
        "**/*.{ts,js}",
        "!dist/**",
        "!target/**",
        "!node_modules/**",
        "!coverage/**",
        "eslint.config.js"
      ]
    },
    "lint:fix:rust": {
      "command": "cargo clippy --fix --allow-dirty --allow-staged",
      "files": [
        "src/**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ]
    }
  }
}
