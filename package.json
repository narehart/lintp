{
  "name": "lintp",
  "version": "0.1.3",
  "description": "File system linter with a custom DSL for directory structure validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lintp": "./bin/lintp"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:rust": "cargo build --release",
    "typecheck": "tsc --noEmit",
    "check:ts": "tsc --noEmit",
    "check:rust": "cargo check",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:ts": "echo \"Error: no test specified\" && exit 1",
    "test:rust": "cargo test",
    "sync-toml": "tsx scripts/sync-toml-to-package.ts",
    "prepublishOnly": "npm run build && npm run sync-toml",
    "format": "prettier --write .",
    "format:ts": "prettier --write .",
    "format:check": "prettier --check .",
    "format:ts:check": "prettier --check .",
    "format:rust": "cargo fmt",
    "format:rust:check": "cargo fmt -- --check",
    "lint": "eslint .",
    "lint:ts": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts:fix": "eslint . --fix",
    "lint:rust": "cargo clippy -- -D warnings",
    "lint:rust:fix": "cargo clippy --fix --allow-dirty --allow-staged",
    "prepare": "husky",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narehart/lintp.git"
  },
  "keywords": [
    "linter",
    "file-system",
    "naming-conventions",
    "dsl",
    "validation",
    "cli",
    "rust",
    "fs",
    "path",
    "directory-structure"
  ],
  "author": "Nico Arehart",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/narehart/lintp/issues"
  },
  "homepage": "https://narehart.github.io/lintp/",
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=14"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.7",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "prettier-plugin-rust": "^0.1.9",
    "smol-toml": "^1.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
