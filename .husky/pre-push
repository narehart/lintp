#!/bin/sh

echo "Running pre-push checks..."

# Run lint
echo "Running lint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Please fix lint errors before pushing."
  exit 1
fi

# Run type check
echo "Running type check..."
npm run check
if [ $? -ne 0 ]; then
  echo "❌ Type check failed. Please fix type errors before pushing."
  exit 1
fi

# Run prettier check
echo "Running prettier check..."
npm run format:check
if [ $? -ne 0 ]; then
  echo "❌ Prettier check failed. Please format your code before pushing."
  exit 1
fi

# Run tests
echo "Running tests..."
npm run test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix failing tests before pushing."
  exit 1
fi

echo "✅ All pre-push checks passed!"